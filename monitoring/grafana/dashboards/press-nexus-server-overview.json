{
  "id": null,
  "uid": "press-nexus-server-overview",
  "title": "Press Nexus Server Overview",
  "tags": [
    "press-nexus",
    "infrastructure"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(node_uname_info, instance)",
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "current": {
          "selected": true,
          "text": "node-exporter:9100",
          "value": "node-exporter:9100"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Usage (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{instance=\"$instance\", mode=\"idle\"}[5m])))",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Load Average",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_load1{instance=\"$instance\"}",
          "legendFormat": "load1"
        },
        {
          "refId": "B",
          "expr": "node_load5{instance=\"$instance\"}",
          "legendFormat": "load5"
        },
        {
          "refId": "C",
          "expr": "node_load15{instance=\"$instance\"}",
          "legendFormat": "load15"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{instance=\"$instance\"} / node_memory_MemTotal_bytes{instance=\"$instance\"}))",
          "legendFormat": "memory"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Filesystem Usage (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - (node_filesystem_avail_bytes{instance=\"$instance\", fstype!~\"tmpfs|fuse.lxcfs|overlay\", mountpoint!~\"/run($|/.*)|/var/lib/docker($|/.*)\"} / node_filesystem_size_bytes{instance=\"$instance\", fstype!~\"tmpfs|fuse.lxcfs|overlay\", mountpoint!~\"/run($|/.*)|/var/lib/docker($|/.*)\"}))",
          "legendFormat": "{{mountpoint}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk IO Throughput (bytes/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (device) (rate(node_disk_read_bytes_total{instance=\"$instance\", device!~\"loop.*|ram.*\"}[5m]))",
          "legendFormat": "{{device}} read"
        },
        {
          "refId": "B",
          "expr": "sum by (device) (rate(node_disk_written_bytes_total{instance=\"$instance\", device!~\"loop.*|ram.*\"}[5m]))",
          "legendFormat": "{{device}} write"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Network Throughput (bytes/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (device) (rate(node_network_receive_bytes_total{instance=\"$instance\", device!~\"lo|docker.*|veth.*|br-.*\"}[5m]))",
          "legendFormat": "{{device}} rx"
        },
        {
          "refId": "B",
          "expr": "sum by (device) (rate(node_network_transmit_bytes_total{instance=\"$instance\", device!~\"lo|docker.*|veth.*|br-.*\"}[5m]))",
          "legendFormat": "{{device}} tx"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Uptime",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - node_boot_time_seconds{instance=\"$instance\"}"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Filesystem Free",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_filesystem_avail_bytes{instance=\"$instance\", mountpoint=\"/\", fstype!~\"tmpfs|fuse.lxcfs|overlay\"}"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    }
  ]
}
