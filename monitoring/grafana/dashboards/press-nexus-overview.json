{
  "id": null,
  "uid": "press-nexus-overview",
  "title": "Press Nexus Overview",
  "tags": [
    "press-nexus",
    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "application",
        "type": "query",
        "label": "Application",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(application_ready_time_seconds, application)",
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "current": {
          "selected": true,
          "text": "app",
          "value": "app"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Pipeline Backlog",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (stage, state) (press_pipeline_backlog{application=\"$application\"})",
          "legendFormat": "{{stage}} {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job Skips (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (exported_job, reason) (increase(press_jobs_skipped_total{application=\"$application\"}[1h]))",
          "legendFormat": "{{exported_job}} {{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pipeline Throughput (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (stage, outcome) (rate(press_pipeline_stage_events_total{application=\"$application\"}[5m]))",
          "legendFormat": "{{stage}} {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pipeline p95 Duration (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(press_pipeline_stage_duration_seconds_bucket{application=\"$application\", outcome=\"success\"}[5m])))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "External HTTP Requests Rate (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (client, outcome) (rate(press_http_client_requests_total{application=\"$application\"}[5m]))",
          "legendFormat": "{{client}} {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "External HTTP p95 Duration (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, client) (rate(press_http_client_duration_seconds_bucket{application=\"$application\"}[5m])))",
          "legendFormat": "{{client}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job Runs (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "sum by (exported_job, outcome) (increase(press_jobs_runs_total{application=\"$application\"}[1h]))",
          "legendFormat": "{{exported_job}} {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backlog Average (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "expr": "sum by (stage, state) (avg_over_time(press_pipeline_backlog{application=\"$application\"}[1h]))",
          "legendFormat": "{{stage}} {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backlog Peak (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "sum by (stage, state) (max_over_time(press_pipeline_backlog{application=\"$application\"}[1h]))",
          "legendFormat": "{{stage}} {{state}}",
          "refId": "A"
        }
      ]
    }
  ]
}
