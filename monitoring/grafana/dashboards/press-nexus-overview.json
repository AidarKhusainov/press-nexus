{
  "id": null,
  "uid": "press-nexus-overview",
  "title": "Press Nexus Overview",
  "tags": ["press-nexus", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "application",
        "type": "query",
        "label": "Application",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(press_queue_depth, application)",
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "current": {
          "selected": true,
          "text": "app",
          "value": "app"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Queue Depth",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (queue) (press_queue_depth{application=\"$application\"})",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue Events Rate (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (queue, event) (rate(press_queue_events_total{application=\"$application\"}[5m]))",
          "legendFormat": "{{queue}} {{event}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pipeline Throughput (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (stage, outcome) (rate(press_pipeline_stage_events_total{application=\"$application\"}[5m]))",
          "legendFormat": "{{stage}} {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pipeline p95 Duration (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(press_pipeline_stage_duration_seconds_bucket{application=\"$application\", outcome=\"success\"}[5m])))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "External HTTP Requests Rate (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (client, outcome) (rate(press_http_client_requests_total{application=\"$application\"}[5m]))",
          "legendFormat": "{{client}} {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "External HTTP p95 Duration (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, client) (rate(press_http_client_duration_seconds_bucket{application=\"$application\"}[5m])))",
          "legendFormat": "{{client}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job Runs (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (job, outcome) (increase(press_jobs_runs_total{application=\"$application\"}[1h]))",
          "legendFormat": "{{job}} {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Delivery Messages (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum by (channel, outcome) (increase(press_delivery_messages_total{application=\"$application\"}[1h]))",
          "legendFormat": "{{channel}} {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Delivery Batch Size Sum (1h)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum by (channel) (increase(press_delivery_batch_sent_sum{application=\"$application\"}[1h]))",
          "legendFormat": "{{channel}}",
          "refId": "A"
        }
      ]
    }
  ]
}
